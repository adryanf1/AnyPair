<?xml version="1.0" encoding="utf-8"?>
<ScrollView xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:fillViewport="true"
    android:background="?android:attr/colorBackground"
    android:fitsSystemWindows="true">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:padding="24dp">

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginTop="8dp"
            android:text="Ajustes"
            android:textSize="32sp"
            android:fontFamily="sans-serif-medium"
            android:textColor="?android:attr/colorAccent"
            android:layout_marginBottom="24dp" />

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="APARIENCIA"
            android:textSize="12sp"
            android:textColor="?android:attr/colorAccent"
            android:fontFamily="sans-serif-medium"
            android:layout_marginBottom="8dp"
            android:layout_marginStart="8dp"/>

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:background="@drawable/bg_icon_card"
            android:orientation="vertical"
            android:padding="20dp"
            android:layout_marginBottom="24dp">
            
            <Switch
                android:id="@+id/sw_blur"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="Efecto cristal (Blur)"
                android:textSize="16sp"
                android:textColor="?android:attr/textColorPrimary" />

            <View android:layout_width="match_parent" android:layout_height="1dp" android:background="#20808080" android:layout_marginTop="16dp" android:layout_marginBottom="16dp"/>

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Subtítulo del pop-up"
                android:textSize="14sp"
                android:textColor="?android:attr/textColorSecondary" />
                
            <EditText
                android:id="@+id/et_subtitulo"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:hint="Ej. Conectado al Moto G05"
                android:paddingTop="8dp"
                android:paddingBottom="8dp"
                android:background="@null"
                android:textSize="16sp"
                android:textColor="?android:attr/textColorPrimary" />
                
            <View android:layout_width="match_parent" android:layout_height="1dp" android:background="#20808080" android:layout_marginTop="8dp" android:layout_marginBottom="16dp"/>

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Texto del botón"
                android:textSize="14sp"
                android:textColor="?android:attr/textColorSecondary" />
                
            <EditText
                android:id="@+id/et_boton"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:hint="Ej. Listo"
                android:paddingTop="8dp"
                android:paddingBottom="8dp"
                android:background="@null"
                android:textSize="16sp"
                android:textColor="?android:attr/textColorPrimary" />
        </LinearLayout>

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="COMPORTAMIENTO"
            android:textSize="12sp"
            android:textColor="?android:attr/colorAccent"
            android:fontFamily="sans-serif-medium"
            android:layout_marginBottom="8dp"
            android:layout_marginStart="8dp"/>

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:background="@drawable/bg_icon_card"
            android:orientation="vertical"
            android:padding="20dp"
            android:layout_marginBottom="24dp">

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Duración en pantalla"
                android:textSize="16sp"
                android:textColor="?android:attr/textColorPrimary"
                android:layout_marginBottom="12dp" />
                
            <RadioGroup
                android:id="@+id/rg_tiempo"
                android:layout_width="match_parent"
                android:layout_height="wrap_content">
                <RadioButton android:id="@+id/rb_3s" android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="3 Segundos" android:textColor="?android:attr/textColorSecondary"/>
                <RadioButton android:id="@+id/rb_7s" android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="7 Segundos" android:textColor="?android:attr/textColorSecondary"/>
                <RadioButton android:id="@+id/rb_inf" android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="Infinito" android:textColor="?android:attr/textColorSecondary"/>
            </RadioGroup>
        </LinearLayout>

        <Button
            android:id="@+id/btn_permisos"
            android:layout_width="match_parent"
            android:layout_height="56dp"
            android:text="Gestionar Permisos del Sistema"
            android:textAllCaps="false"
            android:textSize="16sp"
            android:fontFamily="sans-serif-medium"
            android:textColor="?android:attr/colorAccent"
            android:background="@drawable/bg_icon_card" />

        <View android:layout_width="match_parent" android:layout_height="0dp" android:layout_weight="1" android:minHeight="24dp"/>

        <Button
            android:id="@+id/btn_guardar"
            android:layout_width="match_parent"
            android:layout_height="64dp"
            android:layout_marginBottom="16dp"
            android:text="Guardar Cambios"
            android:textAllCaps="false"
            android:textSize="18sp"
            android:fontFamily="sans-serif-medium"
            android:textColor="#FFFFFF"
            android:background="@drawable/bg_button" />
    </LinearLayout>
</ScrollView>
